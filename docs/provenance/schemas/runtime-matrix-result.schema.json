{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://zaereo.invalid/schemas/runtime-matrix-result/v1",
  "title": "ZaeREo private runtime matrix result",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema",
    "schema_version",
    "result",
    "run_id",
    "scenario_file_sha256",
    "started_utc",
    "finished_utc",
    "total",
    "passed",
    "failed",
    "scenarios",
    "manual_command_delivery",
    "publication_status"
  ],
  "properties": {
    "schema": {
      "const": "zaereo.runtime-matrix-result/v1"
    },
    "schema_version": {
      "const": 1
    },
    "result": {
      "enum": [
        "passed",
        "failed"
      ]
    },
    "run_id": {
      "type": "string",
      "pattern": "^[a-z0-9][a-z0-9_.-]*$"
    },
    "scenario_file_sha256": {
      "$ref": "#/$defs/sha256"
    },
    "started_utc": {
      "$ref": "#/$defs/utc"
    },
    "finished_utc": {
      "$ref": "#/$defs/utc"
    },
    "total": {
      "type": "integer",
      "minimum": 1
    },
    "passed": {
      "type": "integer",
      "minimum": 0
    },
    "failed": {
      "type": "integer",
      "minimum": 0
    },
    "scenarios": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "id",
          "map",
          "result",
          "duration_seconds",
          "report",
          "launch_protocol",
          "command_delivery",
          "failure"
        ],
        "properties": {
          "id": {
            "type": "string",
            "pattern": "^[a-z0-9][a-z0-9_.-]*$"
          },
          "map": {
            "type": "string",
            "pattern": "^[A-Za-z0-9_][A-Za-z0-9_.-]*$"
          },
          "result": {
            "enum": [
              "passed",
              "failed",
              "no-report",
              "invalid-report"
            ]
          },
          "duration_seconds": {
            "type": "number",
            "minimum": 0
          },
          "report": {
            "type": "string",
            "pattern": "^\\.install/runtime-matrix/[a-z0-9][a-z0-9_.-]*/[a-z0-9][a-z0-9_.-]*\\.json$"
          },
          "launch_protocol": {
            "type": [
              "string",
              "null"
            ]
          },
          "command_delivery": {
            "type": [
              "string",
              "null"
            ]
          },
          "focus_diagnostic": {
            "type": [
              "object",
              "null"
            ]
          },
          "failure": {
            "type": "string"
          }
        },
        "allOf": [
          {
            "if": {
              "properties": {
                "result": {
                  "const": "passed"
                }
              },
              "required": [
                "result"
              ]
            },
            "then": {
              "properties": {
                "failure": {
                  "const": ""
                }
              }
            }
          }
        ]
      }
    },
    "publication_status": {
      "const": "private-local-only"
    },
    "manual_command_delivery": {
      "type": "boolean"
    }
  },
  "allOf": [
    {
      "if": {
        "properties": {
          "result": {
            "const": "passed"
          }
        },
        "required": [
          "result"
        ]
      },
      "then": {
        "properties": {
          "failed": {
            "const": 0
          }
        }
      }
    }
  ],
  "$defs": {
    "sha256": {
      "type": "string",
      "pattern": "^[0-9a-f]{64}$"
    },
    "utc": {
      "type": "string",
      "pattern": "^[0-9]{4}-[0-9]{2}-[0-9]{2}T[0-9]{2}:[0-9]{2}:[0-9]{2}Z$"
    }
  }
}
