{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://zaereo.invalid/schemas/dependency-policy.schema.json",
  "title": "ZaeREo dependency and license-harvest policy",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "$schema",
    "schema",
    "policy_id",
    "revision",
    "vcpkg",
    "spdx",
    "project",
    "packages",
    "toolchain_components"
  ],
  "properties": {
    "$schema": { "const": "schemas/dependency-policy.schema.json" },
    "schema": { "const": "zaereo.dependency-policy/v1" },
    "policy_id": { "type": "string", "minLength": 1 },
    "revision": { "type": "integer", "minimum": 1 },
    "vcpkg": {
      "type": "object",
      "additionalProperties": false,
      "required": ["manifest", "builtin_baseline", "status_file"],
      "properties": {
        "manifest": { "type": "string", "minLength": 1 },
        "builtin_baseline": { "type": "string", "pattern": "^[0-9a-f]{40}$" },
        "status_file": { "type": "string", "minLength": 1 }
      }
    },
    "spdx": {
      "type": "object",
      "additionalProperties": false,
      "required": ["version", "data_license", "schema_path", "schema_sha256", "generator", "generator_version"],
      "properties": {
        "version": { "const": "SPDX-2.3" },
        "data_license": { "const": "CC0-1.0" },
        "schema_path": { "type": "string", "minLength": 1 },
        "schema_sha256": { "type": "string", "pattern": "^[0-9a-f]{64}$" },
        "generator": { "const": "ZaeREo generate_sbom.py" },
        "generator_version": { "type": "string", "pattern": "^[0-9]+\\.[0-9]+\\.[0-9]+$" }
      }
    },
    "project": {
      "type": "object",
      "additionalProperties": false,
      "required": ["name", "spdx_id", "official_repository", "official_commit", "license_concluded", "license_declared", "copyright_text"],
      "properties": {
        "name": { "type": "string", "minLength": 1 },
        "spdx_id": { "$ref": "#/$defs/spdxId" },
        "official_repository": { "type": "string", "minLength": 1 },
        "official_commit": { "type": "string", "pattern": "^[0-9a-f]{40}$" },
        "license_concluded": { "type": "string", "minLength": 1 },
        "license_declared": { "type": "string", "minLength": 1 },
        "copyright_text": { "type": "string", "minLength": 1 }
      }
    },
    "packages": {
      "type": "array",
      "minItems": 1,
      "items": { "$ref": "#/$defs/package" }
    },
    "toolchain_components": {
      "type": "array",
      "minItems": 1,
      "items": { "$ref": "#/$defs/toolchain" }
    }
  },
  "$defs": {
    "spdxId": {
      "type": "string",
      "pattern": "^SPDXRef-[A-Za-z0-9.-]+$"
    },
    "package": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "name",
        "version",
        "architecture",
        "spdx_id",
        "role",
        "direct",
        "license_concluded",
        "license_declared",
        "copyright_path",
        "copyright_sha256",
        "license_filename"
      ],
      "properties": {
        "name": { "type": "string", "pattern": "^[a-z0-9][a-z0-9-]*$" },
        "version": { "type": "string", "minLength": 1 },
        "architecture": { "type": "string", "minLength": 1 },
        "spdx_id": { "$ref": "#/$defs/spdxId" },
        "role": { "enum": ["runtime-static", "build-only"] },
        "direct": { "type": "boolean" },
        "license_concluded": { "type": "string", "minLength": 1 },
        "license_declared": { "type": "string", "minLength": 1 },
        "copyright_path": { "type": "string", "minLength": 1 },
        "copyright_sha256": { "type": "string", "pattern": "^[0-9a-f]{64}$" },
        "license_filename": { "type": "string", "pattern": "^[A-Za-z0-9._-]+\\.txt$" }
      }
    },
    "toolchain": {
      "type": "object",
      "additionalProperties": false,
      "required": ["name", "version", "spdx_id", "supplier", "role", "linkage", "license_concluded", "license_declared", "scope_status"],
      "properties": {
        "name": { "type": "string", "minLength": 1 },
        "version": { "type": "string", "minLength": 1 },
        "spdx_id": { "$ref": "#/$defs/spdxId" },
        "supplier": { "type": "string", "minLength": 1 },
        "role": { "enum": ["compiler", "runtime-library"] },
        "linkage": { "enum": ["build-tool", "static"] },
        "license_concluded": { "type": "string", "minLength": 1 },
        "license_declared": { "type": "string", "minLength": 1 },
        "scope_status": { "enum": ["engineering-record-only", "reviewed-for-distribution"] }
      }
    }
  }
}
