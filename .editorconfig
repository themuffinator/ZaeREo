root = true

[*]
charset = utf-8
end_of_line = lf
insert_final_newline = true
trim_trailing_whitespace = true

[*.{c,cc,cpp,cxx,h,hh,hpp,hxx}]
indent_style = tab
indent_size = 4
tab_width = 4

[*.py]
indent_style = space
indent_size = 4

[*.ps1]
indent_style = space
indent_size = 4

[*.{json,jsonc,yml,yaml}]
indent_style = space
indent_size = 2

[*.{xml,vcxproj,filters,props,targets}]
indent_style = space
indent_size = 2

[*.{bat,cmd,sln,vcxproj,filters}]
end_of_line = crlf

[*.md]
indent_style = space
indent_size = 2
trim_trailing_whitespace = false
