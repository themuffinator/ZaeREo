{
  "version": "0.2.0",
  "configurations": [
    {
      "name": "ZaeREo: Run verified windowed runtime smoke",
      "type": "cppvsdbg",
      "request": "launch",
      "program": "pwsh.exe",
      "cwd": "${workspaceFolder}",
      "args": [
        "-NoLogo",
        "-NoProfile",
        "-File",
        "${workspaceFolder}\\tools\\run_game.ps1",
        "-EngineRoot",
        "${input:q2RereleaseEngineRoot}",
        "-UserRoot",
        "${input:q2RereleaseUserRoot}",
        "-Map",
        "${input:zaereoRuntimeMap}"
      ],
      "stopAtEntry": false,
      "console": "integratedTerminal",
      "internalConsoleOptions": "neverOpen"
    }
  ],
  "inputs": [
    {
      "id": "q2RereleaseEngineRoot",
      "type": "promptString",
      "description": "Read-only Quake II Rerelease engine/data root containing baseq2"
    },
    {
      "id": "q2RereleaseUserRoot",
      "type": "promptString",
      "description": "Writable Rerelease user-data parent containing the managed zaereo install"
    },
    {
      "id": "zaereoRuntimeMap",
      "type": "promptString",
      "default": "zbase1",
      "description": "Map name for the verified smoke run (letters, digits, underscore, dot, or hyphen only)"
    }
  ]
}
