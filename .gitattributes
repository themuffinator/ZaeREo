# Normalize repository text so generated manifests and packages are reproducible.
* text=auto eol=lf

*.bat text eol=crlf
*.cmd text eol=crlf
*.sln text eol=crlf
*.vcxproj text eol=crlf
*.filters text eol=crlf

# Binary formats must never be line-normalized or text-diffed.
*.dll binary
*.exe binary
*.lib binary
*.pdb binary
*.pak binary
*.zip binary
*.7z binary

# Source assets, when redistribution is cleared, are stored through Git LFS.
# Generated PAK/ZIP artifacts remain ignored and must not be committed.
*.bsp filter=lfs diff=lfs merge=lfs -text
*.cin filter=lfs diff=lfs merge=lfs -text
*.md2 filter=lfs diff=lfs merge=lfs -text
*.sp2 filter=lfs diff=lfs merge=lfs -text
*.wal filter=lfs diff=lfs merge=lfs -text
*.pcx filter=lfs diff=lfs merge=lfs -text
*.tga filter=lfs diff=lfs merge=lfs -text
*.wav filter=lfs diff=lfs merge=lfs -text
*.ogv filter=lfs diff=lfs merge=lfs -text
